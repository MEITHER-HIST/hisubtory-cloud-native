{
  "family": "hisub-v2-app-task",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "REPLACE_ME",
      "cpu": 256,
      "memory": 512,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ]
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::714454205561:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::714454205561:role/ecsTaskRole"
}
