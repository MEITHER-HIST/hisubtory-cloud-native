{
  "family": "hisub-v2-app-task",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "REPLACE_ME",
      "cpu": 256,
      "memory": 512,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hisub-v2-app-task",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::714454205561:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::714454205561:role/ecsTaskRole"
}
